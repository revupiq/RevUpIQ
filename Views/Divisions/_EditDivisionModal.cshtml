@model RevUpIQ.Admin.Models.Division.DivisionDto
@using RevUpIQ.Admin.Models.Divisions

@{
    var bg = ViewData["DivisionBackground"] as DivisionBackground;
}

<div style="max-width:1200px; margin:30px auto; padding:20px;">

    <div style="display:flex; gap:24px; align-items:flex-start;">

        <div style="flex:1;">

            <div style="display:flex; gap:16px; align-items:center; margin-bottom:12px;">
                @if (!string.IsNullOrWhiteSpace(Model?.LogoUrl))
                {
                    <img src="@Model.LogoUrl"
                         style="width:80px; height:80px; border-radius:12px; object-fit:cover;" />
                }

                <div>
                    <h1 style="margin:0;">@Model?.Name</h1>

                    <div style="display:flex; gap:10px; margin-top:8px;">
                        <button id="openEdit" type="button" class="admin-button">
                            Edit Division
                        </button>

                        <form asp-controller="Divisions"
                              asp-action="Delete"
                              method="post"
                              onsubmit="return confirm('Delete this division permanently?');">
                            <input type="hidden" name="id" value="@Model?.Id" />
                            <button type="submit"
                                    class="admin-button"
                                    style="background:#c0392b;">
                                Delete Division
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>

        <div style="width:260px; display:flex; flex-direction:column; gap:12px;">

            <div style="
                width:100%;
                aspect-ratio: 9 / 16;
                border-radius:20px;
                overflow:hidden;
                background:#0f1e2d;
                display:flex;
                align-items:center;
                justify-content:center;
            ">
                @if (bg != null && !string.IsNullOrWhiteSpace(bg.Background_Url))
                {
                    <img src="@bg.Background_Url"
                         style="width:100%; height:100%; object-fit:cover;" />
                }
            </div>

            <label class="admin-button" style="cursor:pointer; width:fit-content;">
                Upload Background
                <input type="file"
                       id="divisionBackgroundInput"
                       accept="image/*"
                       style="display:none;" />
            </label>

        </div>

    </div>

</div>



<div id="editModal" style="
        display:none;
        position:fixed;
        inset:0;
        background:rgba(0,0,0,0.4);
        z-index:9999;
        justify-content:center;
        align-items:center;
     ">
    <div style="
        background:#1e1e1e;
        padding:24px;
        border-radius:12px;
        width:480px;
        max-width:90%;
        box-sizing:border-box;
        position:relative;
        display:flex;
        flex-direction:column;
        gap:12px;
    ">

        <button id="closeEdit" type="button" style="
                    position:absolute;
                    top:8px;
                    right:8px;
                    width:25px;
                    height:25px;
                    border:none;
                    border-radius:50%;
                    background:#444;
                    color:white;
                    cursor:pointer;
                ">
            ✕
        </button>

        <h2 style="margin:0 0 10px 0;">Edit Division</h2>

        <form asp-controller="Divisions" asp-action="Edit" method="post" enctype="multipart/form-data"
            style="padding:0 12px;">

            <input type="hidden" name="Id" value="@Model?.Id" />

            <label>Name</label>
            <input type="text" name="Name" value="@Model?.Name" class="admin-input" />

            <label>Description</label>


            <label>Logo</label>
            <input type="file" name="Logo" class="admin-input" accept="image/*" />

            <button type="submit" class="admin-button" style="margin-top:10px;">
                Save Changes
            </button>
        </form>
    </div>
</div>


@using RevUpIQ.Admin.Models.MiniGames
@model TriviaSubmission

<style>
    .trivia-section-container {
        margin-top: 25px;
        display: flex;
        justify-content: center;
        width: 100%;
    }

    .trivia-card-title {
        color: white;
        font-size: 22px;
        font-weight: 600;
        text-align: center;
        margin-bottom: 15px;
    }

    .trivia-card {
        background: var(--mid-dark-blue);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 20px;
        width: 100%;
        max-width: 650px;
        color: white;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .trivia-card-label {
        color: var(--light-blue);
        font-weight: 600;
    }
</style>

<div class="trivia-section-container">
    <div style="width: 100%; max-width: 650px;">

        <div class="trivia-card-title">Trivia Suggestion</div>

        <div class="trivia-card">
            <div>
                <span class="trivia-card-label">Question:</span> @Model.Question
            </div>

            <div>
                <span class="trivia-card-label">Correct Answer:</span> @Model.Correct_Answer
            </div>

            <div>
                <span class="trivia-card-label">Incorrect 1:</span> @Model.Incorrect_Answer_1
            </div>

            <div>
                <span class="trivia-card-label">Incorrect 2:</span> @Model.Incorrect_Answer_2
            </div>

            <div>
                <span class="trivia-card-label">Incorrect 3:</span> @Model.Incorrect_Answer_3
            </div>

            <div>
                <span class="trivia-card-label">Created:</span> @Model.Created_At
            </div>

            <div>
                <span class="trivia-card-label">Updated:</span> @Model.Updated_At
            </div>
        </div>

    </div>
</div>

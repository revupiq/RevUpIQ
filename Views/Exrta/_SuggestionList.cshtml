@using RevUpIQ.Admin.Models.MiniGames
@model IEnumerable<CombinedSuggestion>

<link rel="stylesheet" href="~/css/suggestions.css" />

@{
    var list = Model?.ToList() ?? new List<CombinedSuggestion>();
    string currentMode = ViewBag.Mode ?? "Combined";
}

@if (!list.Any())
{
    <div style="text-align:center; color:white;">No data found.</div>
}
else
{
    <div class="suggestion-list">
        @foreach (var item in list)
        {
            if (item == null) continue;

            var username = item.UserProfile?.Profile?.Username ?? "Unknown User";
            var img = item.UserProfile?.Profile?.Profile_Photo_Url;

            long suggestionId =
                item.RaceWord?.Id ??
                item.Trivia?.Id ??
                item.PhotoGuess?.Id ?? 0;

            string question =
                item.RaceWord?.Word ??
                item.Trivia?.Question ??
                item.PhotoGuess?.Question ?? "";

            string created =
                item.RaceWord?.Created_At?.ToString() ??
                item.Trivia?.Created_At?.ToString() ??
                item.PhotoGuess?.Created_At?.ToString() ?? "";

            string itemMode =
                item.RaceWord != null ? GameModeType.RaceWord.ToString() :
                item.Trivia != null ? GameModeType.Trivia.ToString() :
                item.PhotoGuess != null ? GameModeType.PhotoGuess.ToString() :
                currentMode;

            <div class="suggestion-card clickable"
                 onclick="openSuggestion(@suggestionId, '@itemMode')">

                <div class="suggestion-left">
                    <img src="@img" class="suggestion-avatar" />

                    <div class="suggestion-content">
                        <div class="suggestion-row">
                            <span class="suggestion-label">User:</span> @username
                        </div>
                        <div class="suggestion-row">
                            <span class="suggestion-label">Question:</span> @question
                        </div>
                        <div class="suggestion-row">
                            <span class="suggestion-label">Created:</span> @created
                        </div>
                    </div>
                </div>

                <button class="delete-btn" type="button"
                        onclick="event.stopPropagation(); deleteSuggestion(@suggestionId, '@itemMode', '@currentMode')">
                    <svg class="delete-icon" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6l-1 14H6L5 6"></path>
                        <path d="M10 11v6"></path>
                        <path d="M14 11v6"></path>
                        <path d="M9 6V4h6v2"></path>
                    </svg>
                    Delete
                </button>

            </div>
        }
    </div>
}

<script>
    function openSuggestion(id, mode) {
        if (!id) return;
        window.location = `/UsersSuggestion/SuggestionDetails?id=${id}&mode=${encodeURIComponent(mode)}`;
    }

    function deleteSuggestion(id, itemMode, filterMode) {
        fetch(`/UsersSuggestion/DeleteSuggestion?id=${id}&mode=${encodeURIComponent(itemMode)}`)
            .then(() => {
                if (typeof loadSuggestions === "function") {
                    loadSuggestions(filterMode);
                }
            });
    }
</script>

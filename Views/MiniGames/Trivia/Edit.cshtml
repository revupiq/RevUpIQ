@using RevUpIQ.Admin.Models.MiniGames
@{
    var game = ViewData["GameData"] as TriviaDailyDto;
}

<div class="trivia-game">

    @if (game == null)
    {
        <div class="trivia-error">No Trivia Data Loaded</div>
    }
    else
    {
        <form class="trivia-edit" method="post" action="/MiniGames/UpdateTrivia" id="triviaEditForm">

            <input type="hidden" name="id" value="@game.Id" />

            <textarea class="edit-question" name="Question" rows="3">@game.Question</textarea>


            <div class="trivia-options">
                <div class="option-box correct">
                    <div class="option-label">CORRECT ANSWER</div>
                    <input class="edit-option correct" type="text" name="RealAnswer" value="@game.RealAnswer" />
                </div>
                <div class="option-box">
                    <div class="option-label">OPTION A</div>
                    <input class="edit-option" type="text" name="Answer1" value="@game.Answer1" />
                </div>

                <div class="option-box">
                    <div class="option-label">OPTION B</div>
                    <input class="edit-option" type="text" name="Answer2" value="@game.Answer2" />
                </div>

                <div class="option-box">
                    <div class="option-label">OPTION C</div>
                    <input class="edit-option" type="text" name="Answer3" value="@game.Answer3" />
                </div>
            </div>

            <button type="submit" class="admin-button save-btn" disabled>
                Save Changes
            </button>

        </form>
    }

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const form = document.getElementById("triviaEditForm");
        if (!form) return;

        const saveBtn = form.querySelector(".save-btn");
        const inputs = form.querySelectorAll("input, textarea");

        function validateForm() {
            let valid = true;

            inputs.forEach(el => {
                if (!el.value.trim()) valid = false;
            });

            saveBtn.disabled = !valid;
            saveBtn.style.opacity = valid ? "1" : "0.5";
            saveBtn.style.cursor = valid ? "pointer" : "not-allowed";
        }

        inputs.forEach(el => el.addEventListener("input", validateForm));

        validateForm();
    });
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {

        const form = document.getElementById("triviaEditForm");
        if (!form) return;

        form.addEventListener("submit", function (e) {
            e.preventDefault();

            const formData = new FormData(form);

            fetch(form.action, {
                method: "POST",
                body: formData
            })
                .then(res => {
                    if (res.ok) {
                        window.history.back();
                    } else {
                        alert("Error saving trivia.");
                    }
                })
                .catch(() => {
                    alert("Error saving trivia.");
                });
        });

    });
</script>
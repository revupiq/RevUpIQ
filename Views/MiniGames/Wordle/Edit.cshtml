@using RevUpIQ.Admin.Models.MiniGames
@{
    var game = ViewData["GameData"] as RaceWordDailyDto;
    var currentWord = (game?.TargetWord ?? "").ToUpper().Trim();
    var wordLength = Math.Clamp(currentWord.Length == 0 ? 5 : currentWord.Length, 4, 6);
}

<div class="trivia-game">
    @if (game == null)
    {
        <div class="trivia-error">No RaceWord Loaded</div>
    }
    else
    {
        <form class="trivia-edit" method="post" action="/MiniGames/UpdateRaceWord" id="raceWordEditForm">
            <input type="hidden" name="id" value="@game.Id" />
            <input type="hidden" name="TargetWord" id="TargetWordInput" />

            <select name="WordLength" class="admin-select" id="wordLengthSelect">
                <option value="4" selected="@(wordLength == 4)">4 letters</option>
                <option value="5" selected="@(wordLength == 5)">5 letters</option>
                <option value="6" selected="@(wordLength == 6)">6 letters</option>
            </select>

            <div class="wordle-board">
                <div class="wordle-row" id="wordleRow">
                    @{
                        var padded = currentWord.PadRight(wordLength);
                        for (int i = 0; i < wordLength; i++)
                        {
                            var ch = padded[i] == ' ' ? "" : padded[i].ToString();
                            <input class="wordle-cell" type="text" maxlength="1" value="@ch" />
                        }
                    }
                </div>
            </div>

            <button type="submit" class="admin-button save-btn" disabled>Save Changes</button>
        </form>
    }
</div>

<style>
.wordle-board{margin-top:20px}
.wordle-row{display:flex;gap:12px;justify-content:center}
.wordle-cell{width:60px;height:60px;border-radius:14px;border:3px solid var(--bright-blue);background:var(--dark-blue);color:var(--white);font-size:28px;font-weight:800;text-align:center;outline:none}
.wordle-cell:focus{box-shadow:0 0 0 2px var(--light-blue)}
</style>

<script>
document.addEventListener("DOMContentLoaded",function(){
const form=document.getElementById("raceWordEditForm");
if(!form)return;
const saveBtn=form.querySelector(".save-btn");
const targetInput=document.getElementById("TargetWordInput");
const select=document.getElementById("wordLengthSelect");
const row=document.getElementById("wordleRow");

const getCells=()=>Array.from(form.querySelectorAll(".wordle-cell"));
const expectedLength=()=>parseInt(select.value,10);

function rebuildCells(length){
row.innerHTML="";
for(let i=0;i<length;i++){
const input=document.createElement("input");
input.className="wordle-cell";
input.type="text";
input.maxLength=1;
row.appendChild(input);
}
}

function validateForm(){
const cells=getCells();
const isValid=cells.length===expectedLength()&&cells.every(c=>c.value.trim().length===1);
saveBtn.disabled=!isValid;
saveBtn.style.opacity=isValid?"1":"0.5";
saveBtn.style.cursor=isValid?"pointer":"not-allowed";
}

function attachBehavior(){
const cells=getCells();
cells.forEach((cell,index)=>{
cell.oninput=function(){
cell.value=cell.value.toUpperCase().replace(/[^A-Z]/g,"").slice(0,1);
if(cell.value&&cells[index+1])cells[index+1].focus();
validateForm();
};
cell.onkeydown=function(e){
if(e.key==="Backspace"&&!cell.value&&cells[index-1])cells[index-1].focus();
validateForm();
};
});
validateForm();
}

function setupBoardFromCurrent(){
const prev=getCells().map(c=>(c.value||"").toUpperCase()).join("");
rebuildCells(expectedLength());
attachBehavior();
const cells=getCells();
for(let i=0;i<Math.min(prev.length,cells.length);i++){
cells[i].value=prev[i].replace(/[^A-Z]/g,"").slice(0,1);
}
if(cells[0])cells[0].focus();
validateForm();
}

attachBehavior();

select.addEventListener("change",setupBoardFromCurrent);

form.addEventListener("submit",function(e){
e.preventDefault();
validateForm();
if(saveBtn.disabled)return;
let word="";
getCells().forEach(c=>word+=(c.value||"").toUpperCase());
if(word.length!==expectedLength())return;
targetInput.value=word;
const formData=new FormData(form);
fetch(form.action,{method:"POST",body:formData})
.then(res=>{if(res.ok)window.history.back();else alert("Error saving RaceWord.");})
.catch(()=>alert("Error saving RaceWord."));
});
});
</script>

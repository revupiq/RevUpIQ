@using RevUpIQ.Admin.Models.Sponsors
@model IEnumerable<BusinessInquiry>

@{
    var list = Model?.ToList() ?? new List<BusinessInquiry>();
}

@if (!list.Any())
{
    <div style="color:white; text-align:center; margin-top:40px;">
        No sponsor requests found.
    </div>
}
else
{
    <div style="margin:40px auto; max-width:900px; color:white;">
        <h2 style="text-align:center; margin-bottom:20px;">Sponsor Requests</h2>

        <table style="width:100%; border-collapse:collapse; font-size:14px;">
            <thead>
                <tr style="background-color:var(--mid-dark-blue);">
                    <th style="text-align:left; padding:8px; border-bottom:1px solid #333;">Business</th>
                    <th style="text-align:left; padding:8px; border-bottom:1px solid #333;">Contact Name</th>
                    <th style="text-align:left; padding:8px; border-bottom:1px solid #333;">Email</th>
                    <th style="text-align:left; padding:8px; border-bottom:1px solid #333;">Phone</th>
                    <th style="text-align:left; padding:8px; border-bottom:1px solid #333;">Created</th>
                    <th style="padding:8px; border-bottom:1px solid #333; text-align:center;">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in list)
                {
                    <tr>
                        <td style="padding:8px; border-bottom:1px solid #222;">@item.Business_Name</td>
                        <td style="padding:8px; border-bottom:1px solid #222;">@item.Contact_Name</td>
                        <td style="padding:8px; border-bottom:1px solid #222;">@item.Email</td>
                        <td style="padding:8px; border-bottom:1px solid #222;">@item.Phone</td>
                        <td style="padding:8px; border-bottom:1px solid #222;">@item.Created_At</td>

                        <td style="padding:8px; border-bottom:1px solid #222; text-align:center;">
                            <button onclick="deleteSponsor(@item.Id)"
                                    style="
                                        padding:6px 12px;
                                        background-color:#d9534f;
                                        color:white;
                                        border:none;
                                        border-radius:6px;
                                        cursor:pointer;
                                    ">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<script>
    function deleteSponsor(id) {
        if (!confirm("Are you sure you want to delete this request?")) return;

        fetch(`/SponsorsRequests/Delete?id=${id}`)
            .then(() => location.reload());
    }
</script>

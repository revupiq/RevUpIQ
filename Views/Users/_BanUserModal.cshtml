@model Guid

<style>
    .ban-modal-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.65);
        z-index: 1000;
    }

    .ban-modal {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 420px;
        background: #0b0b0b;
        color: #fff;
        border-radius: 12px;
        z-index: 1001;
        box-shadow: 0 20px 60px rgba(0,0,0,.7);
    }

    .ban-modal-header {
        padding: 16px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #222;
    }

    .ban-modal-title {
        font-weight: 600;
    }

    .ban-modal-close {
        background: none;
        border: none;
        color: #aaa;
        font-size: 18px;
        cursor: pointer;
    }

    .ban-modal-body {
        padding: 18px;
    }

    .ban-modal-desc {
        font-size: .9rem;
        color: #ccc;
        margin-bottom: 14px;
    }

    .ban-modal-label {
        font-size: .8rem;
        color: #aaa;
        margin-bottom: 6px;
    }

    .ban-modal-controls {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
    }

    .ban-modal-input,
    .ban-modal-select {
        padding: 10px;
        border-radius: 8px;
        background: #111;
        border: 1px solid #222;
        color: #fff;
    }

    .ban-modal-input {
        flex: 1;
    }

    .ban-modal-until {
        font-size: .8rem;
        color: #999;
        margin-bottom: 18px;
    }

    .ban-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .ban-confirm {
        background: #c97a1a;
    }
</style>


<div id="ban-modal-backdrop" class="ban-modal-backdrop"></div>

<div id="ban-modal" class="ban-modal">
    <div class="ban-modal-header">
        <span class="ban-modal-title">Confirm to ban user</span>
        <button type="button" id="ban-close" class="ban-modal-close">×</button>
    </div>

    <div class="ban-modal-body">
        <div class="ban-modal-desc">
            This will revoke the user's access to your project and prevent them from logging in for a specified duration.
        </div>

        <div class="ban-modal-label">Set a ban duration</div>

        <div class="ban-modal-controls">
            <input id="ban-value" type="number" value="24" min="1" class="ban-modal-input" />

            <select id="ban-unit" class="ban-modal-select">
                <option value="hours">Hours</option>
                <option value="days">Days</option>
            </select>
        </div>

        <div id="ban-until" class="ban-modal-until"></div>

        <div class="ban-modal-actions">
            <button type="button" id="ban-cancel" class="admin-button">Cancel</button>
            <button type="button" id="ban-confirm" class="admin-button ban-confirm" data-user-id="@Model">
                Confirm ban
            </button>
        </div>
    </div>
</div>